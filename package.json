{
    "name": "@gruncellka/porto-features",
    "version": "0.2.0",
    "description": "Shared BDD feature files for Porto SDKs",
    "author": "gruncellka",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/gruncellka/porto-features.git"
    },
    "homepage": "https://github.com/gruncellka/porto-features",
    "bugs": {
        "url": "https://github.com/gruncellka/porto-features/issues"
    },
    "keywords": [
        "bdd",
        "gherkin",
        "cucumber",
        "features",
        "porto"
    ],
    "files": [
        "porto_features/features",
        "porto_features/fixtures",
        "README.md",
        "CHANGELOG.md",
        "LICENSE",
        "index.js",
        "index.d.ts"
    ],
    "main": "index.js",
    "types": "index.d.ts",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "require": "./index.js",
            "default": "./index.js"
        }
    },
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "typescript": "~5.9.3"
    }
}
